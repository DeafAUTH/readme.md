// Summary bar
let bar_width = 40usize;
let filled = if total > 0 { (done * bar_width) / total } else { 0 };
let bar: String = "█".repeat(filled) + &"░".repeat(bar_width - filled);
println!("  \x1b[32m{bar}\x1b[0m  {done}/{total}  \x1b[33m{elapsed:.1}s\x1b[0m");
println!();

// Status legend — visual only
println!("  \x1b[32m■\x1b[0m done  \x1b[33m▶\x1b[0m running  \x1b[34m·\x1b[0m pending  \x1b[31m✗\x1b[0m failed  \x1b[90m–\x1b[0m skipped");
println!();

// Group by tier
let mut tiers: Vec<u8> = apps.iter().map(|a| a.tier).collect();
tiers.sort_unstable();
tiers.dedup();

for tier in tiers {
    let tier_label = match tier {
        0 => "CORE  (T0)",
        1 => "GOV   (T1)",
        2 => "APPS  (T2)",
        _ => "OTHER",
    };
    println!("  \x1b[90m── {tier_label} ──────────────────────────────────\x1b[0m");

    for app in apps.iter().filter(|a| a.tier == tier) {
        let status = statuses.get(&app.name).unwrap_or(&BuildStatus::Pending);
        let (icon, color) = match status {
            BuildStatus::Success(d) => (format!("■  {:.1}s", d.as_secs_f32()), "\x1b[32m"),
            BuildStatus::Running    => ("▶  ···".into(), "\x1b[33m"),
            BuildStatus::Failed(e)  => (format!("✗  {}", &e[..e.len().min(28)]), "\x1b[31m"),
            BuildStatus::Pending    => ("·  ---".into(), "\x1b[34m"),
            BuildStatus::Skipped    => ("–  skip".into(), "\x1b[90m"),
