// ============================================================
// CLI entry — subcommands
// ============================================================
fn main() {
let args: Vec<String> = std::env::args().collect();
let cmd = args.get(1).map(|s| s.as_str()).unwrap_or(“help”);

```
let all_apps = registry();

match cmd {
    "build" => {
        let parallel = args.get(2).map(|s| s == "--parallel").unwrap_or(false);
        let filter: Option<&str> = args.get(2).map(|s| s.as_str())
            .filter(|s| !s.starts_with("--"));

        let apps: Vec<App> = if let Some(f) = filter {
            all_apps.into_iter().filter(|a| a.name.contains(f) || a.kind.label() == f).collect()
        } else {
            all_apps
        };

        println!("\x1b[1m\x1b[32m[mbtq]\x1b[0m building {} apps  parallel={parallel}", apps.len());
        run_builds(apps, parallel);
    }
    "list" => {
        println!("\x1b[1m[mbtq] app registry\x1b[0m\n");
        for app in &all_apps {
            let port = app.port.map(|p| format!(":{p}")).unwrap_or_default();
            println!(
                "  {}[{:7}]\x1b[0m  {:<24} \x1b[90m{}{}\x1b[0m",
                app.kind.color_code(), app.kind.label(),
                app.name, app.path, port
            );
        }
    }
    "check" => {
        println!("\x1b[1m[mbtq] type-check all deno services\x1b[0m\n");
        let deno_apps: Vec<App> = all_apps.into_iter()
            .filter(|a| a.kind == AppKind::DenoService)
            .collect();
        for app in &deno_apps {
            let ok = Command::new("deno")
                .args(["check", "mod.ts"])
                .current_dir(&app.path)
                .status()
                .map(|s| s.success())
                .unwrap_or(false);
            let icon = if ok { "\x1b[32m■\x1b[0m" } else { "\x1b[31m✗\x1b[0m" };
            println!("  {icon}  {}", app.name);
        }
    }
    "wasm" => {
        println!("\x1b[1m[mbtq] build all wasm packages\x1b[0m\n");
        let wasm_apps: Vec<App> = all_apps.into_iter()
            .filter(|a| a.kind == AppKind::WasmPkg)
            .collect();
        run_builds(wasm_apps, false);
    }
    "deploy" => {
        println!("\x1b[1m[mbtq] deploy cloudflare workers\x1b[0m\n");
        let worker_apps: Vec<App> = all_apps.into_iter()
            .filter(|a| a.kind == AppKind::CloudflareWorker)
            .collect();
        run_builds(worker_apps, true);
    }
    "help" | _ => {
        println!("\x1b[1m\x1b[32mmbtq-cli\x1b[0m  deaf-first build orchestrator\n");
        println!("  \x1b[33mbuild\x1b[0m [filter] [--parallel]   build all or filtered apps");
        println!("  \x1b[33mlist\x1b[0m                           list all registered apps");
        println!("  \x1b[33mcheck\x1b[0m                          deno type-check all services");
        println!("  \x1b[33mwasm\x1b[0m                           compile all wasm packages");
        println!("  \x1b[33mdeploy\x1b[0m                         deploy cloudflare workers");
        println!();
        println!("  \x1b[90mall output visual-only — no audio gates\x1b[0m");
    }
}
