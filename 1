pub fn render_dashboard(
apps: &[App],
statuses: &HashMap<String, BuildStatus>,
start: Instant,
) {
// Clear screen + move to top
print!(”\x1b[2J\x1b[H”);

```
// Header
println!("\x1b[1m\x1b[32m┌─────────────────────────────────────────────────────┐\x1b[0m");
println!("\x1b[1m\x1b[32m│  MBTQ BUILD ORCHESTRATOR  ·  deaf-first  ·  visual  │\x1b[0m");
println!("\x1b[1m\x1b[32m└─────────────────────────────────────────────────────┘\x1b[0m");
println!();

let elapsed = start.elapsed().as_secs_f32();
let total = apps.len();
let done = statuses.values().filter(|s| matches!(s, BuildStatus::Success(_))).count();
let failed = statuses.values().filter(|s| matches!(s, BuildStatus::Failed(_))).count();
let running = statuses.values().filter(|s| matches!(s, BuildStatus::Running)).count();
