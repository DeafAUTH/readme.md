// ============================================================
// Parallel build runner with dependency ordering
// ============================================================
pub fn run_builds(apps: Vec<App>, parallel: bool) {
let statuses: Arc<Mutex<HashMap<String, BuildStatus>>> = Arc::new(Mutex::new(
apps.iter().map(|a| (a.name.clone(), BuildStatus::Pending)).collect()
));
let start = Instant::now();

```
if parallel {
    let handles: Vec<_> = apps.iter().cloned().map(|app| {
        let statuses = Arc::clone(&statuses);
        thread::spawn(move || {
            {
                let mut s = statuses.lock().unwrap();
                s.insert(app.name.clone(), BuildStatus::Running);
            }
            let t0 = Instant::now();
            let result = build_app(&app);
            let mut s = statuses.lock().unwrap();
            s.insert(app.name.clone(), match result {
                Ok(()) => BuildStatus::Success(t0.elapsed()),
                Err(e) => BuildStatus::Failed(e),
            });
        })
    }).collect();

    // Render loop while building
    loop {
        {
            let s = statuses.lock().unwrap();
            render_dashboard(&apps, &s, start);
            let all_done = s.values().all(|s| !matches!(s, BuildStatus::Pending | BuildStatus::Running));
            if all_done { break; }
        }
        thread::sleep(Duration::from_millis(200));
    }

    for h in handles { let _ = h.join(); }
} else {
    // Sequential — respects dep ordering
    for app in &apps {
        {
            let mut s = statuses.lock().unwrap();
            s.insert(app.name.clone(), BuildStatus::Running);
        }
        render_dashboard(&apps, &statuses.lock().unwrap(), start);

        let t0 = Instant::now();
        let result = build_app(app);
        let mut s = statuses.lock().unwrap();
        s.insert(app.name.clone(), match result {
            Ok(()) => BuildStatus::Success(t0.elapsed()),
            Err(e) => BuildStatus::Failed(e),
        });
    }
}

// Final render
render_dashboard(&apps, &statuses.lock().unwrap(), start);
println!("\n  \x1b[1m\x1b[32mBUILD COMPLETE\x1b[0m  total: {:.2}s\n", start.elapsed().as_secs_f32());
```

