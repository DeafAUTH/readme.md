// ============================================================
// Build executor — per AppKind
// ============================================================
pub fn build_app(app: &App) -> Result<(), String> {
let cmds: Vec<(&str, Vec<&str>)> = match app.kind {
AppKind::DenoService => vec![
(“deno”, vec![“check”, “mod.ts”]),
(“deno”, vec![“task”, “build”]),
],
AppKind::NextJs => vec![
(“npm”, vec![“ci”, “–prefer-offline”]),
(“npm”, vec![“run”, “build”]),
],
AppKind::ViteReact => vec![
(“npm”, vec![“ci”, “–prefer-offline”]),
(“npm”, vec![“run”, “build”]),
],
AppKind::RustBin => vec![
(“cargo”, vec![“build”, “–release”]),
],
AppKind::WasmPkg => vec![
(“wasm-pack”, vec![“build”, “–target”, “web”, “–release”]),
],
AppKind::CloudflareWorker => vec![
(“npm”, vec![“ci”, “–prefer-offline”]),
(“wrangler”, vec![“deploy”, “–dry-run”]),
],
AppKind::TerraformModule => vec![
(“terraform”, vec![“validate”]),
(“terraform”, vec![“plan”, “-out=tfplan”]),
],
};

```
for (bin, args) in cmds {
    let status = Command::new(bin)
        .args(&args)
        .current_dir(&app.path)
        .stdout(Stdio::null())
        .stderr(Stdio::piped())
        .status()
        .map_err(|e| format!("{bin} not found: {e}"))?;

    if !status.success() {
        return Err(format!("{bin} {} failed (exit {:?})", args.join(" "), status.code()));
    }
}
Ok(())
